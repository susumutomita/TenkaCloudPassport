{
  "name": "tenkacloud-passport",
  "version": "0.1.0-alpha.1",
  "description": "TenkaCloud のイベントで確認済みの手掛かりから人間同士の会話を始める、アカウント不要の Expo アプリ。",
  "author": "Susumu Tomita <oyster880@gmail.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/susumutomita/TenkaCloudPassport.git"
  },
  "homepage": "https://github.com/susumutomita/TenkaCloudPassport#readme",
  "bugs": {
    "url": "https://github.com/susumutomita/TenkaCloudPassport/issues"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.13.0"
  },
  "trustedDependencies": [],
  "scripts": {
    "start": "expo start --go",
    "dev": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build": "bun run build:web",
    "build:web": "expo export --platform web --output-dir dist",
    "test": "bun test",
    "test:coverage": "bun test src --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.scripts.json",
    "expo:check": "expo install --check",
    "clean": "rimraf .expo dist coverage",
    "lint": "bun biome check .",
    "lint:fix": "bun biome check --write .",
    "lint:text": "bun textlint README.md",
    "check:pre-release": "bun scripts/architecture-harness.ts --pre-release --fail-on=error",
    "dup:check": "bun scripts/check-duplication.ts",
    "dup:baseline": "bun scripts/check-duplication.ts --update",
    "dead-code": "knip --no-config-hints",
    "lint-staged": "lint-staged",
    "format": "bun biome format --write .",
    "format:check": "bun biome format .",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@noble/hashes": "2.2.0",
    "expo": "~57.0.7",
    "expo-build-properties": "~57.0.6",
    "expo-dev-client": "~57.0.7",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "llama.rn": "0.12.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.7.0",
    "@types/bun": "^1.3.11",
    "@types/react": "~19.2.2",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12",
    "jsqr": "^1.4.0",
    "knip": "^6.27.0",
    "lint-staged": "^17.0.7",
    "rimraf": "^6.1.3",
    "textlint": "^15.7.1",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-inappropriate-words": "^2.0.0",
    "textlint-rule-no-double-negative-ja": "^2.0.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-prefer-tari-tari": "^1.0.3",
    "textlint-rule-preset-ja-spacing": "^2.2.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-spellcheck-tech-word": "^5.0.0",
    "typescript": "~6.0.3",
    "wrangler": "^4.112.0"
  }
}
